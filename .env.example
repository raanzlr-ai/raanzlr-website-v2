# Frontend port
PORT=5173
BASE_PATH=/

# API Server port (should be different from frontend)
API_PORT=3000

# Database connection — Supabase (cloud PostgreSQL)
DATABASE_URL=postgresql://postgres.<your-project-ref>:<your-db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Supabase REST API (used by frontend and n8n)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Supabase service role (server-side only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ─── n8n Webhooks (optional) ──────────────────────────────────────────────────
# VITE_N8N_CONTACT_WEBHOOK=https://your-n8n-instance.com/webhook/contact-general
# VITE_N8N_SERVICE_WEBHOOK=https://your-n8n-instance.com/webhook/contact-service
# N8N_BLOG_WEBHOOK=https://your-n8n-instance.com/webhook/blog-new-post
# N8N_BLOG_WEBHOOK_SECRET=your-secret-here
